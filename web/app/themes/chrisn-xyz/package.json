{
  "name": "chrisn-xyz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "prebuild": "concurrently yarn:test yarn:typecheck yarn:lint",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "concurrently yarn:lint:* yarn:typecheck:*",
    "lint:eslint": "eslint assets --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:stylelint": "stylelint assets/**/*.scss"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.2.1",
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "stylelint": "^15.10.3",
    "stylelint-config-standard-scss": "^11.0.0",
    "stylelint-prettier": "^4.0.2",
    "stylelint-selector-bem-pattern": "^3.0.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vite-plugin-manifest-sri": "^0.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "import"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:prettier/recommended",
      "plugin:import/recommended",
      "plugin:import/typescript",
      "plugin:jest-dom/recommended"
    ]
  },
  "stylelint": {
    "plugins": [
      "stylelint-selector-bem-pattern"
    ],
    "extends": [
      "stylelint-config-standard-scss",
      "stylelint-prettier/recommended"
    ],
    "rules": {
      "selector-class-pattern": null,
      "prettier/prettier": true,
      "plugin/selector-bem-pattern": {
        "preset": "bem"
      }
    }
  },
  "prettier": {
    "trailingComma": "all",
    "printWidth": 120,
    "importOrder": [
      "^[.].*(?!css)$"
    ],
    "importOrderSeparation": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@fontsource/b612": "^5.2.7",
    "@fontsource/noto-sans": "^5.2.10"
  }
}
